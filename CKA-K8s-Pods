pod-deploymeny.yml
apiversion: v1
kind: Pod
metadata: 
  name: myapp-pods
  labels:
       app: myapp
       type: front-end
spec:
  containers:
  - name: nginx-container
    image: nginx

definition-------------
apiversion: v1 for each object it will be different 
kind: pod (name of the object) 
metadata: 
  name: myapp-pods (name of the pods)
  labels:
       app: myapp (label the pod)
       type: front-end (for which server - frontend backend)
spec:
  containers: there are lots of things there under spec, container is one of them (list/array) list of containers in the same pod
    -name: nginx-container (- defines the first container from the list) 
     image: nginx 
      



# kubectl create -f pod-deployment.yml
